{
  "name": "edurite-frontend",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "typecheck": "tsc --noEmit",
    "lint": "npm run typecheck",
    "test": "vitest run",
    "validate:encoding": "node ./scripts/validate-encoding.mjs",
    "audit:deps": "npm audit",
    "verify": "npm run validate:encoding && npm run typecheck && npm test -- --run && npm run build",
    "check:dist": "node ./scripts/verify-dist.mjs",
    "check:served-build": "node ./scripts/verify-served-build.mjs"
  },
  "dependencies": {
    "@hookform/resolvers": "^3.9.0",
    "@tanstack/react-query": "^5.56.2",
    "axios": "^1.18.1",
    "framer-motion": "^12.38.0",
    "lucide-react": "^0.446.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-hook-form": "^7.53.0",
    "react-router-dom": "^6.30.4",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^25.6.0",
    "@types/react": "^18.3.5",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^6.0.3",
    "autoprefixer": "^10.4.20",
    "postcss": "^8.5.20",
    "tailwindcss": "^3.4.10",
    "typescript": "^5.5.4",
    "vite": "^8.1.5",
    "vitest": "^4.1.10"
  },
  "postcss": {
    "plugins": {
      "tailwindcss": {},
      "autoprefixer": {}
    }
  },
  "overrides": {
    "form-data": "^4.0.6",
    "micromatch": {
      "picomatch": "^2.3.2"
    }
  }
}
